# India Hiring Dashboard - Environment Variables
# 
# Instructions:
# 1. Copy this file and rename to: .env.local
# 2. Fill in your actual values
# 3. Never commit .env.local to GitHub (it's in .gitignore)
# 4. In Vercel Dashboard, add these as Environment Variables

# Get FILE_ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/[FILE_ID]/edit
NEXT_PUBLIC_SHEET_FILE_ID=your_file_id_here

# Get API_KEY from Google Cloud Console:
# https://console.cloud.google.com → Credentials → Create API Key
NEXT_PUBLIC_DRIVE_API_KEY=your_api_key_here
